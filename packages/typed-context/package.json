{
  "name": "effection-typed-context",
  "version": "0.1.0",
  "description": "Type-aware context helpers for Effection operations.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./types": {
      "default": "./ambient.d.ts",
      "types": "./ambient.d.ts"
    }
  },
  "files": [
    "dist",
    "ambient.d.ts",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "tsc --w",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "prepublish": "pnpm build",
    "prepack": "pnpm run build",
    "typecheck": "tsc --noEmit",
    "version": "changeset version",
    "release": "changeset publish",
    "build": "tsc -p tsconfig.json"
  },
  "keywords": [
    "effection",
    "context",
    "types",
    "typescript",
    "generators"
  ],
  "author": "Joshua Amaju <joshsemail4work@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/joshamaju/typed-context/tree/main/packages/typed-context#readme",
  "bugs": {
    "url": "https://github.com/joshamaju/typed-context/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joshamaju/typed-context.git",
    "directory": "packages/typed-context"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.14.0",
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "effection": "^4.0.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "effection": "^4.0.2"
  }
}